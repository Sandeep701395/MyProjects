<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>Emp_Management</display-name>
  <welcome-file-list>
    <welcome-file>dashboard.html</welcome-file>
  </welcome-file-list>
  
  <servlet>
  <servlet-name>register</servlet-name>
  <servlet-class>emp_management.RegisterServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  <servlet-name>register</servlet-name>
  <url-pattern>/register</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>login</servlet-name>
  <servlet-class>emp_management.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  <servlet-name>login</servlet-name>
  <url-pattern>/login</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>details</servlet-name>
  <servlet-class>emp_management.DetailsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  <servlet-name>details</servlet-name>
  <url-pattern>/home</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>edit</servlet-name>
  <servlet-class>emp_management.EditDetails</servlet-class>
  </servlet>
  <servlet-mapping>
  <servlet-name>edit</servlet-name>
  <url-pattern>/editEmployee</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>delete</servlet-name>
  <servlet-class>emp_management.DeleteServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  <servlet-name>delete</servlet-name>
  <url-pattern>/deleteEmployee</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>update</servlet-name>
  <servlet-class>emp_management.UpdateServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  <servlet-name>update</servlet-name>
  <url-pattern>/saveChanges</url-pattern>
  </servlet-mapping>
</web-app>