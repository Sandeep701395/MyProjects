		Connection con=null;
		PreparedStatement pre=null;
		ResultSet rs=null;
		
		try {
			Class.forName("com.mysql.cj.jdbc.Driver");
			con=DriverManager.getConnection(url, user, password);
			pre=con.prepareStatement("select * from emps where id=?");
			
			pre.setInt(1, id);
			rs=pre.executeQuery();
			
			if(rs.next())
			{
