<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>Online_Cal</display-name>
  <servlet>
  <servlet-name>multiplication</servlet-name>
  <servlet-class>calculator.Multiplication</servlet-class>
  </servlet>
  <servlet-mapping>
   <servlet-name>multiplication</servlet-name>
	<url-pattern>/mul</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>cube</servlet-name>
  <servlet-class>calculator.CubeServlet</servlet-class>
  </servlet>
  
  <servlet-mapping>
  <servlet-name>cube</servlet-name>
  <url-pattern>/cub</url-pattern>
  
  </servlet-mapping>
  
  <servlet>
  <servlet-name>division</servlet-name>
  <servlet-class>calculator.DivisionSevlet</servlet-class>
  
  </servlet>
  <servlet-mapping>
  <servlet-name>division</servlet-name>
  <url-pattern>/div</url-pattern>
  
  </servlet-mapping>
  
  <error-page>
  <exception-type>java.lang.Throwable</exception-type>
  <location>/exception.html</location>
  
  </error-page>
</web-app>