<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>Online_Calculator_Project</display-name>
  <welcome-file-list>
  <welcome-file>addd.html</welcome-file>
  <welcome-file>index.html</welcome-file>
  <welcome-file>add.html</welcome-file>
  </welcome-file-list>
  
  <servlet>
  <servlet-name>sum</servlet-name>
  <servlet-class>online_calculator.Addition</servlet-class>
  </servlet>
  
  <servlet-mapping>
  <servlet-name>sum</servlet-name>
  <url-pattern>/sum</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>square</servlet-name>
  <servlet-class>online_calculator.SquareServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  <servlet-name>square</servlet-name>
  <url-pattern>/sq</url-pattern>
  </servlet-mapping>
  
  <servlet>
  <servlet-name>division</servlet-name>
  <servlet-class>online_calculator.DivisionServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  <servlet-name>division</servlet-name>
  <url-pattern>/div</url-pattern>
  </servlet-mapping>
  
  <error-page>
  	<exception-type>java.lang.Throwable</exception-type>
  	<location>/exception.html</location>
  </error-page>
  
  <error-page>
  <error-code>404</error-code>
  <location>/resoursenotfound.html</location>
  </error-page>
</web-app>