<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
            http://www.springframework.org/schema/beans/spring-beans.xsd
            http://www.springframework.org/schema/context
            http://www.springframework.org/schema/context/spring-context-3.0.xsd">
            
    <bean id="myball" class="constructor_injection.Ball"> 
    <constructor-arg name="brand" value="Guru"></constructor-arg>
    <constructor-arg name="color" value="Blue"></constructor-arg>
    <constructor-arg name="cost" value="100"></constructor-arg>
     <constructor-arg name="shape" value="circle"></constructor-arg>
    </bean>

</beans>