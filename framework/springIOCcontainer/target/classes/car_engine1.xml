<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:context="http://www.springframework.org/schema/context"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
            http://www.springframework.org/schema/beans/spring-beans.xsd
            http://www.springframework.org/schema/context
            http://www.springframework.org/schema/context/spring-context-3.0.xsd">

	<bean id="myengine" class="setter_injection_using_has_a_relationship.Engine">
		<property name="eid" value="1"></property>
		<property name="cc" value="125cc"></property>
		<property name="type" value="Cng"></property>
	</bean>

	<bean id="mycar" class="setter_injection_using_has_a_relationship.Car">
		<property name="cid" value="101"></property>
		<property name="brand" value="tata"></property>
		<property name="color" value="white"></property>
		<property name="cost" value="600000"></property>
		<property name="engine" ref="myengine"></property>
	</bean>

</beans>