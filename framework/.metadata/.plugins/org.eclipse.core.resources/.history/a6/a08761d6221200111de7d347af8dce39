package org.jsp.springbootdemoapp.controller;

import org.jsp.springbootdemoapp.dto.Demo;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
public class DemoController {

	@GetMapping("/hi")
	public String getMsg()
	{
		return "Hi I Am GetMessage()";
	}
	@PostMapping("/hello")
	public void postMsg()
	{
		System.out.println("Hello I am PostMessage()");
	}
	
	@PostMapping("/savedemo")
	public void saveDemo(Demo demo)
	{
		System.out.println(demo.getDid());
		System.out.println(demo.getName());
	}
}
