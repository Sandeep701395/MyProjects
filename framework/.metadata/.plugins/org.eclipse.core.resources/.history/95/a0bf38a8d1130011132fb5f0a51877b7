package org.jsp.springbootemployeecrud_app.dao;



import java.util.Optional;

import org.jsp.springbootemployeecrud_app.dto.Employee;
import org.jsp.springbootemployeecrud_app.repository.EmployeeRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;
@Repository
public class EmployeeDao {
	@Autowired
	private EmployeeRepository repository;
	
	public void saveEmployee(Employee employee)
	{
		repository.save(employee);
	}
	
	public Employee updateEmployee(Employee employee)
	{
		return repository.save(employee);
	}
	
//	public Optional<Employee> findEmployeeById(int eid)
//	{
//		Optional<Employee> dbEmployee=repository.findById(eid);
//		
//		return dbEmployee;
//	}
	
	public Employee findEmployeeById(int eid)
	{
		Optional<Employee> dbEmployee =repository.findById(eid);
		if(dbEmployee.isPresent())
		{
			return dbEmployee.get();
		}
		else
		{
			return null;
		}
		
	}
	
	public void deleteEmployee(Employee employee)
	{
		repository.delete(employee);
	}
}
