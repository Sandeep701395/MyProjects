package org.jsp.springbootUser1CRUD_app.dao;

import java.util.Optional;

import org.jsp.springbootUser1CRUD_app.dto.User1;
import org.jsp.springbootUser1CRUD_app.repository.User1Repository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Repository;

@Repository
public class User1Dao {
	@Autowired
	private User1Repository repository;
	
	public void saveUser(User1 user)
	{
		repository.save(user);
	}
	
	public void updateUser(User1 user)
	{
		repository.save(user);
	}
	
	public Optional<User1> findUser(User1 user)
	{
		Optional<User1> dbUser=repository.findById(user.getUid());
		return dbUser;
	}
}
